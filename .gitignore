# Environment variables and secrets (Prevents API key leaks)
.env
.env.local
.env.*
.streamlit/secrets.toml
secrets.toml

# Virtual environments
.venv/
venv/
env/
ENV/

# Python cache & build outputs
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
build/
dist/
*.egg-info/

# User PDF/Word documents (Prevents accidental uploads of private CVs/resumes)
*.pdf
*.docx
*.doc
*.txt
!requirements.txt
!README.md
!SUMMARY.md
!SESSION_SUMMARY.md

# Log files
*.log

# Editor and IDE configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# System files
.DS_Store
Thumbs.db
